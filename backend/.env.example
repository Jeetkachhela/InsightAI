# InsightForge AI - Environment Configuration
# Copy this file to .env and replace placeholders with your own secrets.
# NEVER commit .env with real credentials to version control.

# PostgreSQL Database Connection URL
# Example: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=

# Groq API Key for LLM inference
GROQ_API_KEY=

# JWT Configuration
# Secret must be a high-entropy string at least 32 characters long.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AES-256 Encryption Key for database credentials (64 hex characters = 32 bytes)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AES_KEY=

# AES Key Rotation (JSON map of version -> hex key)
# AES_KEYS={"v1": "<64-hex-chars>", "v2": "<64-hex-chars>"}
# ACTIVE_AES_KEY_VERSION=v1

# Allowed CORS Origins (comma-separated)
FRONTEND_ORIGINS=http://localhost:3000

# Environment Mode: development | production
ENV=development
